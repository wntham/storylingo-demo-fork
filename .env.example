# ============================================
# StoryLingo Demo - Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# REQUIRED: Your OpenAI API key
# Get one at: https://platform.openai.com/api-keys
# Must have access to the Realtime API (gpt-realtime model)
OPENAI_API_KEY=sk-your-openai-api-key-here

# REQUIRED: Your OpenAI stored prompt ID
# Create a stored prompt at: https://platform.openai.com/prompts
# See README.md Step 2 for the prompt template to use
OPENAI_PROMPT_ID=pmpt_your-prompt-id-here

# REQUIRED for production: Your deployed app's domain (no https://)
# Example: storylingo-demo-production.up.railway.app
# For local development, set to: localhost:5000
EXPO_PUBLIC_DOMAIN=your-app.up.railway.app

# OPTIONAL: Server port (Railway sets this automatically)
# PORT=5000

# OPTIONAL: Comma-separated allowed CORS origins
# Not needed when client and server share the same domain (e.g. Railway)
# ALLOWED_ORIGINS=https://example.com,https://other.com
