{
  "expo": {
    "name": "StoryLingo",
    "slug": "story-buddy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "storybuddy",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.storybuddy.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "StoryLingo needs microphone access so you can practice speaking with your storyteller friend."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F8F5FF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.storybuddy.app",
      "permissions": ["android.permission.RECORD_AUDIO"]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F8F5FF",
          "dark": {
            "backgroundColor": "#2D1B4E"
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-audio",
        {
          "microphonePermission": "StoryLingo needs microphone access so you can practice speaking with your storyteller friend."
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true
    }
  }
}
